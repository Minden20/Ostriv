<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.geometry.Pos?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
  fx:controller="org.example.ostriv.ostriv.HelloController">
  <padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
  </padding>

  <Label fx:id="welcomeText" text="Натисніть кнопку, щоб завантажити карту"/>
  <Button fx:id="loadButton" text="Завантажити карту" onAction="#onLoadMapClick"/>

  <StackPane VBox.vgrow="ALWAYS">
    <Pane fx:id="mapContainer"/>
    <Label fx:id="coordsLabel" text="" StackPane.alignment="TOP_LEFT" mouseTransparent="true"
           style="-fx-background-color: rgba(0,0,0,0.6); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 6 12 6 12; -fx-background-radius: 0 0 8 0;">
      <StackPane.margin>
        <Insets top="0" left="0"/>
      </StackPane.margin>
    </Label>
  </StackPane>
</VBox>
